# Copy to .env and fill in your values
# Generate a key: openssl rand -hex 16

CINDER_API_KEY=cinder-your-key-here

# Optional: your Tailscale HTTPS URL for remote access from iOS Shortcuts etc.
# Format: https://<machine>.<tailnet>.ts.net:<port>
CINDER_TAILSCALE_URL=https://your-machine.tail1234.ts.net:8445
